generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  VIEWER
}

model User {
  id            String   @id @default(uuid())
  username      String   @unique
  password_hash String
  role          Role     @default(VIEWER)
  created_at    DateTime @default(now())
}